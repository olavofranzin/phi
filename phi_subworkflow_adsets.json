                  {
                      "parameters":  {
                                         "jsCode":  "const source = $input.first().json;\nconst fromGoogle = source.results !== undefined;\n\nlet impressions = 0;\nlet clicks = 0;\nlet cost_brl = 0;\nlet conversions = 0;\nlet revenue = 0;\nlet frequency = null;\n\nif (fromGoogle) {\n  const payload = source;\n  const base = $(\"If IDs Google\").first().json;\n  const metrics = payload.results?.[0]?.metrics || {};\n  impressions = Number(metrics.impressions || 0);\n  clicks = Number(metrics.clicks || 0);\n  cost_brl = Number(metrics.costMicros || 0) / 1000000;\n  conversions = Number(metrics.conversions || 0);\n  revenue = Number(metrics.conversionsValue || 0);\n  return [{\n    json: {\n      ...base,\n      platform: \"google_ads\",\n      metrics: {}\n    }\n  }].map((item) =\u003e {\n    item.json.metrics = {\n      impressions,\n      clicks,\n      cost_brl: Number(cost_brl.toFixed(2)),\n      conversions,\n      revenue: Number(revenue.toFixed(2)),\n      ctr: impressions \u003e 0 ? Number((clicks / impressions).toFixed(6)) : 0,\n      cpc: clicks \u003e 0 ? Number((cost_brl / clicks).toFixed(2)) : 0,\n      cpa: conversions \u003e 0 ? Number((cost_brl / conversions).toFixed(2)) : 0,\n      roas: cost_brl \u003e 0 ? Number((revenue / cost_brl).toFixed(4)) : 0,\n      conversion_rate: clicks \u003e 0 ? Number((conversions / clicks).toFixed(6)) : 0,\n      frequency\n    };\n    return item;\n  });\n}\n\nconst payload = source.data?.[0] || {};\nconst base = $(\"If IDs Meta\").first().json;\nimpressions = Number(payload.impressions || 0);\nclicks = Number(payload.clicks || 0);\ncost_brl = Number(payload.spend || 0);\nfrequency = payload.frequency === undefined ? null : Number(payload.frequency || 0);\n\nconst actionMap = Object.fromEntries((payload.actions || []).map((entry) =\u003e [entry.action_type, Number(entry.value || 0)]));\nconst valueMap = Object.fromEntries((payload.action_values || []).map((entry) =\u003e [entry.action_type, Number(entry.value || 0)]));\nconversions = actionMap[\u0027offsite_conversion.fb_pixel_purchase\u0027] || actionMap[\u0027purchase\u0027] || actionMap[\u0027lead\u0027] || actionMap[\u0027omni_purchase\u0027] || 0;\nrevenue = valueMap[\u0027offsite_conversion.fb_pixel_purchase\u0027] || valueMap[\u0027purchase\u0027] || valueMap[\u0027omni_purchase\u0027] || 0;\n\nreturn [{\n  json: {\n    ...base,\n    platform: \"meta_ads\",\n    metrics: {\n      impressions,\n      clicks,\n      cost_brl: Number(cost_brl.toFixed(2)),\n      conversions,\n      revenue: Number(revenue.toFixed(2)),\n      ctr: impressions \u003e 0 ? Number((clicks / impressions).toFixed(6)) : 0,\n      cpc: clicks \u003e 0 ? Number((cost_brl / clicks).toFixed(2)) : 0,\n      cpa: conversions \u003e 0 ? Number((cost_brl / conversions).toFixed(2)) : 0,\n      roas: cost_brl \u003e 0 ? Number((revenue / cost_brl).toFixed(4)) : 0,\n      conversion_rate: clicks \u003e 0 ? Number((conversions / clicks).toFixed(6)) : 0,\n      frequency\n    }\n  }\n}];"
                                     },
