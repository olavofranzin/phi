                      "parameters":  {
                                         "jsCode":  "const execution_id = $(\"Start\").first().json.execution_id;\nconst source_execution_id = $(\"Start\").first().json.source_execution_id ?? null;\nconst client_id_filter = $(\"Start\").first().json.client_id ?? null;\n\nconst pickPlain = (prop) =\u003e {\n  if (!prop) return null;\n  if (prop.title?.length) return prop.title[0].plain_text?.trim() || null;\n  if (prop.rich_text?.length) return prop.rich_text[0].plain_text?.trim() || null;\n  return null;\n};\n\nconst pickNumber = (prop) =\u003e {\n  const value = prop?.number;\n  return value === null || value === undefined ? null : Number(value);\n};\n\nreturn $input.all().flatMap((item) =\u003e {\n  const props = item.json.properties || {};\n\n  const adset_id_google = pickNumber(props[\"adset_id_google\"]);\n  const adset_id_meta = pickNumber(props[\"adset_id_meta\"]);\n  const customer_id_google = pickNumber(props[\"customer_id_google\"]);\n  const meta_account_id = pickNumber(props[\"meta_account_id\"]);\n  const client_slug = pickPlain(props[\"sigla_cliente\"]);\n\n  if (client_id_filter \u0026\u0026 client_slug \u0026\u0026 client_id_filter !== client_slug) {\n    return [];\n  }\n\n  const platform = adset_id_google ? \"google_ads\" : (adset_id_meta ? \"meta_ads\" : null);\n  if (!platform) return [];\n\n  return [{\n    json: {\n      execution_id,\n      source_execution_id,\n      entity_type: \"adset\",\n      notion_page_id: item.json.id,\n      nome: pickPlain(props[\"Nome\"]),\n      campaign_id: pickPlain(props[\"campaign_id\"]),\n      platform,\n      adset_id_google,\n      adset_id_meta,\n      customer_id_google,\n      meta_account_id\n    }\n  }];\n});"
                                     },
