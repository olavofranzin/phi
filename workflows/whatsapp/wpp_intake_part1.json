            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict" }, "conditions": [{ "leftValue": "={{ $json.etapa }}", "rightValue": "5", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" } },
