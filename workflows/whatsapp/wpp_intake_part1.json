        "jsCode": "const staticData = $getWorkflowStaticData(\"global\");\nconst prospeccao = staticData.prospeccao_params || {};\nconst telefone = $json.telefone;\nprospeccao[telefone] = {\n  segmento: $json.segmento,\n  tipo_localizacao: $json.tipo_localizacao,\n  localizacao: $json.localizacao,\n  tem_site: $json.tem_site,\n  avaliacao_minima: $json.avaliacao_minima,\n  status: 'iniciado',\n  inicio: new Date().toISOString()\n};\nstaticData.prospeccao_params = prospeccao;\nreturn [{ json: $json }];"
      },
