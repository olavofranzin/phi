    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData(\"global\");\nconst conversas = staticData.conversas || {};\nconst telefone = $json.telefone;\nconst mensagem = ($json.mensagem || \"\").trim();\n\nfunction normalizar(str) {\n  return str.toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '').trim();\n}\n\nconst ehKeyword = normalizar(mensagem) === 'iniciar prospeccao';\n\nif (ehKeyword) {\n  conversas[telefone] = { etapa: \"1\" };\n  staticData.conversas = conversas;\n  return [{ json: { telefone, mensagem, etapa: \"1\", segmento: null, tipo_localizacao: null, localizacao: null, tem_site: null, avaliacao_minima: null } }];\n}\n\nif (!conversas[telefone]) {\n  return [];\n}\n\nconst conversa = conversas[telefone];\n\nif (conversa.etapa === \"completo\") {\n  return [];\n}\n\nif (conversa.etapa === \"1\") {\n  conversa.segmento = mensagem;\n  conversa.etapa = \"2\";\n} else if (conversa.etapa === \"2\") {\n  conversa.tipo_localizacao = mensagem;\n  conversa.etapa = \"3\";\n} else if (conversa.etapa === \"3\") {\n  conversa.localizacao = mensagem;\n  conversa.etapa = \"4\";\n} else if (conversa.etapa === \"4\") {\n  conversa.tem_site = mensagem;\n  conversa.etapa = \"5\";\n} else if (conversa.etapa === \"5\") {\n  conversa.avaliacao_minima = mensagem;\n  conversa.etapa = \"completo\";\n}\n\nstaticData.conversas = conversas;\nreturn [{ json: {\n  telefone,\n  mensagem,\n  etapa: conversa.etapa,\n  segmento: conversa.segmento || null,\n  tipo_localizacao: conversa.tipo_localizacao || null,\n  localizacao: conversa.localizacao || null,\n  tem_site: conversa.tem_site || null,\n  avaliacao_minima: conversa.avaliacao_minima || null\n} }];"
      },
      "id": "d0ff77ee-6b8b-4d3d-a03e-8c2faec3e995",
      "name": "Gerenciar estado da conversa",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
