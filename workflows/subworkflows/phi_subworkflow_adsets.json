                      "parameters":  {
                                         "jsCode":  "const execution_id = $(\"Start\").first().json.execution_id;\nconst source_execution_id = $(\"Start\").first().json.source_execution_id ?? null;\nconst client_id_filter = $(\"Start\").first().json.client_id ?? null;\n\nconst pickPlain = (prop) =\u003e {\n  if (!prop) return null;\n  if (prop.title?.length) return prop.title[0].plain_text?.trim() || null;\n  if (prop.rich_text?.length) return prop.rich_text[0].plain_text?.trim() || null;\n  return null;\n};\n\nconst pickNumber = (prop) =\u003e {\n  const value = prop?.number;\n  return value === null || value === undefined ? null : Number(value);\n};\n\nconst pickScalar = (prop) =\u003e {\n  if (!prop) return null;\n  if (prop.number !== undefined \u0026\u0026 prop.number !== null) return prop.number;\n  if (prop.rich_text?.length) return prop.rich_text[0].plain_text?.trim() || null;\n  if (prop.title?.length) return prop.title[0].plain_text?.trim() || null;\n  if (prop.rollup) {\n    if (prop.rollup.type === \"number\") return prop.rollup.number;\n    if (prop.rollup.type === \"date\") return prop.rollup.date?.start || null;\n    if (prop.rollup.type === \"array\") {\n      const first = prop.rollup.array?.[0];\n      if (!first) return null;\n      if (first.type === \"number\") return first.number;\n      if (first.type === \"rich_text\") return first.rich_text?.[0]?.plain_text?.trim() || null;\n      if (first.type === \"title\") return first.title?.[0]?.plain_text?.trim() || null;\n      if (first.type === \"formula\") {\n        if (first.formula?.type === \"number\") return first.formula.number;\n        if (first.formula?.type === \"string\") return first.formula.string?.trim() || null;\n      }\n    }\n  }\n  if (prop.formula) {\n    if (prop.formula.type === \"number\") return prop.formula.number;\n    if (prop.formula.type === \"string\") return prop.formula.string?.trim() || null;\n  }\n  return null;\n};\n\nconst pickIdString = (prop) =\u003e {\n  const value = pickScalar(prop);\n  if (value === null || value === undefined) return null;\n  const normalized = String(value).trim();\n  if (!normalized) return null;\n  return normalized.replace(/[^\\d]/g, \"\") || normalized;\n};\n\nreturn $input.all().flatMap((item) =\u003e {\n  const props = item.json.properties || {};\n\n  const adset_id_google = pickIdString(props[\"adset_id_google\"]);\n  const adset_id_meta = pickIdString(props[\"adset_id_meta\"]);\n  const customer_id_google = pickIdString(props[\"customer_id_google\"]);\n  const meta_account_id = pickIdString(props[\"meta_account_id\"]);\n  const client_slug = pickPlain(props[\"sigla_cliente\"]);\n\n  if (client_id_filter \u0026\u0026 client_slug \u0026\u0026 client_id_filter !== client_slug) {\n    return [];\n  }\n\n  const platform = adset_id_google ? \"google_ads\" : (adset_id_meta ? \"meta_ads\" : null);\n  if (!platform) return [];\n\n  return [{\n    json: {\n      execution_id,\n      source_execution_id,\n      entity_type: \"adset\",\n      notion_page_id: item.json.id,\n      nome: pickPlain(props[\"Nome\"]),\n      campaign_id: pickPlain(props[\"campaign_id\"]),\n      platform,\n      adset_id_google,\n      adset_id_meta,\n      customer_id_google,\n      meta_account_id\n    }\n  }];\n});"
                                     },
