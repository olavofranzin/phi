                                         "jsCode":  "const item = $input.first().json;\nconst result = item.results?.[0];\n\nif (!result) {\n  throw new Error(\u0027Google Ads API não retornou resultados\u0027);\n}\n\nconst metrics = result.metrics;\n\n// Recuperar dados da campanha do node anterior\nconst campaignData = $(\u0027Edit Fields\u0027).first().json;\n\nreturn [{\n  json: {\n    execution_id:         campaignData.execution_id,\n    client_id:            campaignData.client_id,\n    campaign_id:          campaignData.campaign_id,\n    campaign_name:        campaignData.campaign_name,\n    primary_metric_type:  campaignData.primary_metric_type,\n    primary_metric_goal:  campaignData.primary_metric_goal,\n    fonte:                campaignData.fonte,\n    impressions:          parseInt(metrics.impressions || 0),\n    clicks:               parseInt(metrics.clicks || 0),\n    cost:                 parseFloat((parseInt(metrics.costMicros || 0) / 1000000).toFixed(2)),\n    conversions:          parseInt(metrics.conversions || 0),\n    revenue:              parseFloat(metrics.conversionsValue || 0),\n  }\n}];"
