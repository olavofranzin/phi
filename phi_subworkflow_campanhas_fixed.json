                                         "jsCode":  "const items = $input.all();\nconst output = [];\n\nconst execution_id = $(\u0027Start\u0027).first().json.execution_id;\nconst source_execution_id = $(\u0027Start\u0027).first().json.source_execution_id ?? null;\nconst client_id_filter = $(\u0027Start\u0027).first().json.client_id;\n\nif (!execution_id) {\n  throw new Error(\u0027execution_id nÃ£o recebido do workflow principal\u0027);\n}\n\nfor (const item of items) {\n  const props = item.json.properties;\n\n  const status = props[\u0027Status\u0027]?.status?.name?.trim() || null;\n  if (status !== \u0027Em execuÃ§Ã£o\u0027) continue;\n\n  const client_id = props[\u0027client_id\u0027]?.rich_text?.[0]?.plain_text?.trim() || null;\n  if (!client_id) continue;\n\n  const fonte = props[\u0027Fonte\u0027]?.multi_select?.[0]?.name?.trim() || null;\n  const google_id_campaign  = props[\u0027id_google_camp\u0027]?.number ?? null;\n  const campaign_id_google  = google_id_campaign ? `GADS-${google_id_campaign}` : null;\n  const campaign_id_meta    = props[\u0027id_meta_camp\u0027]?.number\n    ? `META-${props[\u0027id_meta_camp\u0027].number}` : null;\n  const campaign_id = fonte === \u0027Google Ads\u0027 ? campaign_id_google\n    : fonte === \u0027Meta Ads\u0027 ? campaign_id_meta\n    : null;\n\n  if (!campaign_id) continue;\n\n  const campaign_name       = props[\u0027Nome da campanha\u0027]?.title?.[0]?.plain_text?.trim() || null;\n  const customer_id_google  = props[\u0027id_google_account\u0027]?.number\n    ? String(props[\u0027id_google_account\u0027].number) : null;\n  const pixel_id_meta       = props[\u0027id_meta_pixel\u0027]?.number\n    ? String(props[\u0027id_meta_pixel\u0027].number) : null;\n  const primary_metric_type = props[\u0027MÃ©trica-MÃ£e\u0027]?.multi_select?.[0]?.name?.trim() || \u0027ROAS\u0027;\n  const primary_metric_goal = props[\u0027Meta da MÃ©trica-mÃ£e\u0027]?.number ?? null;\n\n  output.push({\n    json: {\n      execution_id,\n      source_execution_id,\n      client_id,\n      campaign_name,\n      campaign_id,\n      fonte,\n      customer_id_google,\n      pixel_id_meta,\n      primary_metric_type,\n      primary_metric_goal,\n      google_id_campaign,\n    }\n  });\n}\n\nreturn output;\n"
