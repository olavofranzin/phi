    {
      "parameters": {
        "jsCode": "const contexto = $('[Onb A2.1] Normalizar Contexto').first().json;\nconst rows = $input.all();\nconst pickPlain = (prop) => {\n  if (!prop) return '';\n  if (prop.title?.length) return prop.title.map((item) => item.plain_text || '').join('').trim();\n  if (prop.rich_text?.length) return prop.rich_text.map((item) => item.plain_text || '').join('').trim();\n  return '';\n};\nconst pickSelect = (prop) => prop?.select?.name ?? '';\nconst activeStatuses = new Set(contexto.active_statuses);\nconst duplicate = rows.find((item) => {\n  const props = item.json.properties || {};\n  const nome = pickPlain(props['Cliente']);\n  const nomeNormalizado = nome.trim().toLocaleLowerCase('pt-BR');\n  const status = pickSelect(props['Status']);\n  return activeStatuses.has(status) && nomeNormalizado === contexto.cliente_nome_normalizado;\n});\nif (!duplicate) {\n  return [{ json: { ...contexto, has_duplicate: false } }];\n}\nreturn [{ json: {\n  ...contexto,\n  has_duplicate: true,\n  duplicate_page_id: duplicate.json.id,\n  duplicate_status: pickSelect(duplicate.json.properties?.Status),\n  duplicate_message: 'Onboarding ativo ja existe para este cliente.'\n} }];"
      },
