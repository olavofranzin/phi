    {
      "parameters": {
        "jsCode": "const contexto = $('[Onb A2.1] Detectar Duplicidade').first().json;\nconst users = $input.all().map((item) => item.json);\nconst responsavel = contexto.responsavel_geral_email\n  ? users.find((user) => String(user.person?.email || '').toLowerCase() === contexto.responsavel_geral_email)\n  : null;\nreturn [{ json: {\n  ...contexto,\n  responsavel_geral_id: responsavel?.id ?? null,\n  schema_hints: {\n    cliente_relation_inverse: 'Etapas de Onboarding',\n    etapas_title_property: 'Nome da etapa'\n  },\n  cliente_properties: {\n    cliente_nome: contexto.cliente_nome,\n    status: 'Em andamento',\n    data_inicio: contexto.data_inicio,\n    modelo_negocio: contexto.modelo_negocio,\n    servico: contexto.servico,\n    origem_comercial: contexto.origem_comercial,\n    observacoes: contexto.observacoes,\n    sla_primeira_entrega: 21,\n    responsavel_geral_id: responsavel?.id ?? null\n  }\n} }];"
