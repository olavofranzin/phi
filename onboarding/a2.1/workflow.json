    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst contexto = $('[Onb A2.1] Resolver Responsavel Geral').first().json;\nconst cliente = $('[Onb A2.1] Criar Cliente').first().json;\nconst sucesso = [];\nconst falhas = [];\nfor (const item of items) {\n  const payload = item.json || {};\n  const hasError = Boolean(payload.error || payload.message || payload.stack);\n  if (hasError && !payload.id) {\n    falhas.push(payload.error?.message || payload.message || payload.description || JSON.stringify(payload));\n  } else {\n    sucesso.push(payload.id || payload);\n  }\n}\nreturn [{ json: {\n  cliente_page_id: cliente.id,\n  cliente_nome: contexto.cliente_nome,\n  cnpj_normalizado: contexto.cnpj_normalizado,\n  raw_payload: contexto.raw_payload,\n  etapas_esperadas: items[0]?.json?.etapas_esperadas ?? items.length,\n  etapas_criadas: sucesso.length,\n  etapas_falhas: falhas.length,\n  falha_resumo: falhas.slice(0, 5).join(' | '),\n  workflow_status: sucesso.length === (items[0]?.json?.etapas_esperadas ?? items.length) ? 'ok' : 'partial_failure'\n} }];"
      },
