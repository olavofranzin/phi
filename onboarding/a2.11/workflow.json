                                         "mode":  "runOnceForAllItems",
                                         "jsCode":  "const updates = $(\u0027[Onb A2.11] Preparar Update Observacoes\u0027).all().map((item) =\u003e item.json);\nreturn [{ json: { workflow: \u0027Onb - Disparar CSAT NPS\u0027, clientes_processados: updates.length, evolution_sucesso: updates.filter((item) =\u003e item.evolution_status === \u0027ok\u0027).length, evolution_falha: updates.filter((item) =\u003e item.evolution_status === \u0027falhou\u0027).length, cliente_ids: updates.map((item) =\u003e item.cliente_page_id) } }];"
