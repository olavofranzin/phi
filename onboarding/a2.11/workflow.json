                  {
                      "id":  "f87a34a2-9fbf-4d57-b83e-a0b8c6bc5b0b",
                      "name":  "[Onb A2.11] Filtrar Clientes Elegiveis",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       448,
                                       0
                                   ],
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "jsCode":  "const TARGET_STATUS = \u0027Concluído\u0027;\nconst IDEMPOTENCY_MARK = \u0027A2.11 disparada em\u0027;\nconst pickTitle = (page) =\u003e {\n  for (const prop of Object.values(page.properties || {})) {\n    if (prop?.type === \u0027title\u0027) return (prop.title || []).map((item) =\u003e item.plain_text || \u0027\u0027).join(\u0027\u0027).trim();\n  }\n  return \u0027\u0027;\n};\nconst pickSelect = (prop) =\u003e prop?.select?.name || \u0027\u0027;\nconst pickPlainText = (prop) =\u003e (prop?.rich_text || []).map((item) =\u003e item.plain_text || \u0027\u0027).join(\u0027\u0027);\nconst out = [];\nfor (const item of $input.all()) {\n  const page = item.json || {};\n  const props = page.properties || {};\n  const status = pickSelect(props.Status);\n  const observacoes_atual = pickPlainText(props[\u0027Observações\u0027]);\n  if (status === TARGET_STATUS \u0026\u0026 !observacoes_atual.includes(IDEMPOTENCY_MARK) \u0026\u0026 !page.archived) {\n    out.push({ json: { cliente_page_id: page.id, cliente_nome: pickTitle(page), cliente_status: status, observacoes_atual } });\n  }\n}\nreturn out;"
                                     }
                  },
                  {
                      "id":  "8343f7f9-4e63-4196-8eb8-feb98cdbbe62",
                      "name":  "[Onb A2.11] Montar Mensagem e Links",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       896,
                                       0
                                   ],
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "jsCode":  "const CSAT_FORM_URL = \u0027<CSAT_FORM_URL_redacted>\u0027;\nconst NPS_FORM_URL = \u0027<NPS_FORM_URL_redacted>\u0027;\nconst OLAVO_PHONE = \u0027<OLAVO_PHONE_redacted>\u0027;\nconst out = [];\nfor (const item of $input.all()) {\n  const cliente = item.json || {};\n  const cliente_page_id = cliente.cliente_page_id;\n  const cliente_nome = cliente.cliente_nome || \u0027\u0027;\n  if (!cliente_page_id) {\n    throw new Error(\u0027cliente_page_id ausente - nao montar CSAT/NPS sem cliente\u0027);\n  }\n  const encodedId = encodeURIComponent(cliente_page_id);\n  const encodedName = encodeURIComponent(cliente_nome);\n  const csat_link = `${CSAT_FORM_URL}#cliente=${encodedId}\u0026cliente_nome=${encodedName}`;\n  const nps_link = `${NPS_FORM_URL}#cliente=${encodedId}\u0026cliente_nome=${encodedName}`;\n  const text = `[Onb A2.11] Disparar CSAT/NPS para cliente ${cliente_nome}\nCSAT: ${csat_link}\nNPS: ${nps_link}\nID do cliente=${cliente_page_id}\nAcao: enviar os 2 links ao cliente off-platform.`;\n  out.push({ json: { ...cliente, number: OLAVO_PHONE, csat_link, nps_link, text } });\n}\nreturn out;"
                                     }
                  },
                  {
                      "id":  "742fd55c-92db-4c58-9210-804c5465ad00",
                      "name":  "[Onb A2.11] Enviar via Evolution",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.4,
                      "position":  [
                                       1120,
                                       0
                                   ],
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "<evolution_base_url_redacted>/message/sendText/Whats%20Business",
                                         "authentication":  "predefinedCredentialType",
                                         "nodeCredentialType":  "httpHeaderAuth",
                                         "sendBody":  true,
                                         "contentType":  "json",
                                         "specifyBody":  "json",
