                  {
                      "id":  "d1ebf798-ca68-4a90-8463-8717adc39f58",
                      "name":  "[Onb A2.11] Preparar Update Observacoes",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1344,
                                       0
                                   ],
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "jsCode":  "const mensagens = $(\u0027[Onb A2.11] Montar Mensagem e Links\u0027).all().map((item) =\u003e item.json);\nconst responses = $input.all();\nconst now = new Date();\nconst brTimestamp = now.toLocaleString(\u0027sv-SE\u0027, { timeZone: \u0027America/Sao_Paulo\u0027 }).replace(\u0027 \u0027, \u0027T\u0027) + \u0027-03:00\u0027;\nconst out = [];\nfor (const [index, responseItem] of responses.entries()) {\n  const msg = mensagens[index];\n  if (!msg) continue;\n  const payload = responseItem.json || {};\n  const statusCode = Number(payload.statusCode || payload.response?.statusCode || 0);\n  const failed = Boolean(payload.error || payload.message || (statusCode \u0026\u0026 (statusCode \u003c 200 || statusCode \u003e= 300)));\n  const evolutionStatus = failed ? \u0027falhou\u0027 : \u0027ok\u0027;\n  const detail = statusCode ? `HTTP ${statusCode}` : (failed ? \u0027erro sem status HTTP\u0027 : \u0027\u0027);\n  const linhaNova = `A2.11 disparada em ${brTimestamp}. CSAT: ${msg.csat_link}, NPS: ${msg.nps_link}. Status Evolution: ${evolutionStatus}${detail ? ` (${detail})` : \u0027\u0027}.`;\n  const observacoes_atual = msg.observacoes_atual || \u0027\u0027;\n  const observacoes_finais = observacoes_atual ? `${observacoes_atual}\\n${linhaNova}` : linhaNova;\n  out.push({ json: { ...msg, evolution_status: evolutionStatus, evolution_detail: detail, linha_nova: linhaNova, observacoes_finais } });\n}\nreturn out;"
                                     }
                  },
